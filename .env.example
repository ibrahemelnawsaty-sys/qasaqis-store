####################################################################
#  منصة «قصص أطفال» — qasaqis.store
#  انسخ هذا الملف إلى .env ثم عدّل القيم. لا تضع أسرارًا حقيقية هنا.
####################################################################

APP_NAME="قصص أطفال"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Cairo
APP_URL=http://localhost

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_EG

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------- قاعدة البيانات MySQL (Hostinger) ----------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qasaqis_store
DB_USERNAME=root
DB_PASSWORD=

# ---------- الجلسات/الكاش/الطابور ----------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# على الاستضافة المشتركة إن لم يتوفر Redis استخدم database/file
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------- البريد ----------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@qasaqis.store"
MAIL_FROM_NAME="${APP_NAME}"

# ---------- وسائل تواصل المتجر ----------
STORE_WHATSAPP_NUMBER=201000000000
STORE_PHONE=
STORE_FACEBOOK=
STORE_INSTAGRAM=
STORE_TIKTOK=

####################################################################
#  الدفع
#  ملاحظة (متطلبات العميل + الدستور):
#  - إن لم يوجد مفتاح API مفعّل للبوابة، يُخفى «الدفع الأونلاين» تلقائيًا
#    ويُعرض «الدفع الأونلاين مغلق حاليًا».
#  - الدفع اليدوي (إنستاباي/فودافون كاش/تحويل) و COD تُفعَّل من لوحة الأدمن.
####################################################################

ONLINE_PAYMENT_ENABLED=false
PAYMENT_GATEWAY=paymob

PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

KASHIER_MERCHANT_ID=
KASHIER_API_KEY=
KASHIER_SECRET_KEY=

VITE_APP_NAME="${APP_NAME}"
