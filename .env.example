####################################################################
#  منصة «قصص أطفال» — qasaqis.store
#  انسخ هذا الملف إلى .env ثم عدّل القيم. لا تضع أسرارًا حقيقية هنا.
####################################################################

APP_NAME="قصص أطفال"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Cairo
APP_URL=http://localhost

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_EG

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------- قاعدة البيانات MySQL (Hostinger) ----------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qasaqis_store
DB_USERNAME=root
DB_PASSWORD=

# ---------- الجلسات/الكاش/الطابور ----------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# على الاستضافة المشتركة إن لم يتوفر Redis استخدم database/file
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------- البريد ----------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@qasaqis.store"
MAIL_FROM_NAME="${APP_NAME}"
# بريد احتياطي لتنبيهات الأدمن حين لا يوجد مستخدم نشط بصلاحية orders.view.
MAIL_ADMIN_ADDRESS=

# ---------- وسائل تواصل المتجر ----------
STORE_WHATSAPP_NUMBER=201000000000
STORE_PHONE=
STORE_FACEBOOK=
STORE_INSTAGRAM=
STORE_TIKTOK=

# ---------- الشحن ----------
# التكلفة الافتراضية للشحن (ج.م) — تُضبط هنا أو من لوحة الأدمن، لا تُخترع في الكود.
# القيمة صفر حتى تُحدَّد. يمكن تجاوزها لكل محافظة عبر config/egypt.php.
SHIPPING_FLAT_COST=0.00

####################################################################
#  الدفع
#  ملاحظة (متطلبات العميل + الدستور):
#  - إن لم يوجد مفتاح API مفعّل للبوابة، يُخفى «الدفع الأونلاين» تلقائيًا
#    ويُعرض «الدفع الأونلاين مغلق حاليًا».
#  - الدفع اليدوي (إنستاباي/فودافون كاش/تحويل) و COD تُفعَّل من لوحة الأدمن.
####################################################################

ONLINE_PAYMENT_ENABLED=false
PAYMENT_GATEWAY=paymob

# مهلة إلغاء طلبات الدفع الأونلاين غير المدفوعة (بالساعات) وتحرير مخزونها.
PENDING_ORDER_EXPIRY_HOURS=48

# مهلة الرابط الموقّت المُعاد من صفحة «تتبّع الطلب» (بالدقائق).
ORDER_TRACK_LINK_TTL=60
# مهلة روابط بريد التأكيد/الإشعارات (بالدقائق) — افتراضي 14 يومًا.
ORDER_EMAIL_LINK_TTL=20160

PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# كاشير: MID من لوحة كاشير (بصيغة MID-xxxx-xxx). api_key = «Payment API Key»
# (يولّد هاش الطلب ويتحقّق من التوقيع). secret_key = «Secret Key» لنداءات api.kashier.io.
# لا تكتب القيم الحقيقية هنا — تُوضع في .env على الخادم فقط (بند 4.3).
KASHIER_MERCHANT_ID=
KASHIER_API_KEY=
KASHIER_SECRET_KEY=
# وضع البوابة: test أو live.
KASHIER_MODE=test
# أصل الصفحة المستضافة (افتراضي كافٍ؛ غيّره فقط إن تغيّر نطاق كاشير).
KASHIER_HPP_URL=https://checkout.kashier.io
# طرق الدفع المسموح بها: card,wallet,bank_installments (افصل بفواصل).
KASHIER_ALLOWED_METHODS=card,wallet

####################################################################
#  رصد الأخطاء (Sentry) — لا تضع DSN حقيقيًا هنا
#  إن تُرك SENTRY_LARAVEL_DSN فارغًا يتعطّل الإرسال بصمت.
#  send_default_pii=false لعدم تسريب بيانات العملاء.
####################################################################
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false

####################################################################
#  النسخ الاحتياطي (spatie/laravel-backup)
#  الوجهة: Cloudflare R2 عبر واجهة S3. القيم أسرار — على السيرفر فقط.
#  إلزامي في الإنتاج: BACKUP_ARCHIVE_PASSWORD (يشفّر الأرشيف) — بدونه يفشل
#  backup:run بحارس صريح كي لا تُرفع بيانات العملاء غير مشفّرة.
#  BACKUP_NAME: اسم ASCII للأرشيف (لا تتركه للاسم العربي).
####################################################################
BACKUP_NAME=qasaqis
BACKUP_ARCHIVE_PASSWORD=
BACKUP_NOTIFICATION_EMAIL=
BACKUP_R2_ACCESS_KEY_ID=
BACKUP_R2_SECRET_ACCESS_KEY=
BACKUP_R2_BUCKET=
BACKUP_R2_ENDPOINT=
BACKUP_R2_REGION=auto

####################################################################
#  التحليلات والبكسل (M6) — لا تضع معرّفات/أسرار حقيقية هنا
#  ANALYTICS_ENABLED يبقى false حتى التحقق من الأحداث في الإنتاج.
#  api_secret / capi_token خادميان فقط (لا يُحقنان في الصفحة).
####################################################################
ANALYTICS_ENABLED=false
ANALYTICS_CURRENCY=EGP
GA4_ID=
GA4_API_SECRET=
META_PIXEL_ID=
META_CAPI_TOKEN=
META_CAPI_TEST_EVENT_CODE=

VITE_APP_NAME="${APP_NAME}"
